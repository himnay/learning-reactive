<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        Corporate parent POM.  super-pom itself inherits spring-boot-starter-parent:4.1.0
        and imports llm-bom (Spring Boot 4.1.0, Spring Cloud 2025.1.2).
        This module pins its own Spring Boot / Cloud versions below so it stays on the
        3.4.x train until a deliberate upgrade is made.
    -->
    <parent>
        <groupId>com.org.llm</groupId>
        <artifactId>super-pom</artifactId>
        <version>1.0.0</version>
        <relativePath/>
    </parent>

    <groupId>com.reactivespring</groupId>
    <artifactId>learning-reactive-parent</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>learning-reactive-parent</name>
    <description>Root POM — shared dependency management for all reactive service modules</description>

    <!-- ── Sub-modules ── -->
    <modules>
        <module>non-spring-reactive-reactor-core</module>
        <module>spring-reactive-service-info</module>
        <module>spring-reactive-service-review</module>
        <module>spring-reactive-service-movies</module>
        <module>spring-reactive-gateway</module>
        <module>spring-reactive-service-r2dbc</module>
    </modules>

    <!-- ── Version overrides (super-pom sets java=21, spring-boot=4.1.0, spring-cloud=2025.1.2) ── -->
    <properties>
        <java.version>25</java.version>
        <maven.compiler.release>${java.version}</maven.compiler.release>
        <spring-boot.version>4.1.0</spring-boot.version>
        <spring-cloud.version>2025.1.2</spring-cloud.version>
        <testcontainers.version>1.20.4</testcontainers.version>
        <jjwt.version>0.12.6</jjwt.version>
    </properties>

    <!--
        Spring Boot is inherited from super-pom → llm-bom (4.1.0 + spring-framework 7.x).
        Spring Cloud BOM is imported explicitly to version-manage gateway and contract modules.
        Do NOT import spring-boot-dependencies here — it would downgrade spring-framework
        to an incompatible version (6.x vs the 7.x that spring-boot 4.1.0 requires).
    -->
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- JWT — compile API only; impl+jackson are runtime -->
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-api</artifactId>
                <version>${jjwt.version}</version>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-impl</artifactId>
                <version>${jjwt.version}</version>
                <scope>runtime</scope>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-jackson</artifactId>
                <version>${jjwt.version}</version>
                <scope>runtime</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <!--
                    Pin spring-boot-maven-plugin to 3.4.4.
                    super-pom inherits the plugin from spring-boot-starter-parent:4.1.0,
                    so without this override the 4.1.0 plugin would be used at package time.
                    Child pluginManagement takes precedence over the parent chain.
                -->
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <version>${spring-boot.version}</version>
                    <executions>
                        <execution>
                            <id>repackage</id>
                            <goals>
                                <goal>repackage</goal>
                            </goals>
                        </execution>
                        <!-- build-info inherited from super-pom's <build><plugins> block -->
                    </executions>
                </plugin>

                <plugin>
                    <groupId>org.codehaus.mojo</groupId>
                    <artifactId>build-helper-maven-plugin</artifactId>
                    <version>3.6.0</version>
                </plugin>

                <!-- Skip git-commit-id until the repo has an initial commit -->
                <plugin>
                    <groupId>io.github.git-commit-id</groupId>
                    <artifactId>git-commit-id-maven-plugin</artifactId>
                    <configuration combine.self="override">
                        <skip>true</skip>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>

        <plugins>
            <!--
                Override maven-compiler-plugin configuration inherited from super-pom.
                super-pom configures annotation processor paths for Lombok + Boot config
                processor.  This project uses Java records instead of Lombok, so those
                paths must be removed to avoid a compilation failure on a missing
                Lombok artifact.  combine.self="override" replaces the parent's
                <configuration> block entirely rather than merging into it.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration combine.self="override">
                    <release>${maven.compiler.release}</release>
                    <parameters>true</parameters>
                    <annotationProcessorPaths>
                        <!-- spring-boot-configuration-processor only: generates IDE hints for
                             @ConfigurationProperties classes.  No Lombok — project uses records. -->
                        <path>
                            <groupId>org.springframework.boot</groupId>
                            <artifactId>spring-boot-configuration-processor</artifactId>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

            <!--
                Surefire configuration: shared across all modules.
                - net.bytebuddy.experimental: Mockito needs this for Java 25 (class version 69)
                - api.version: docker-java inside Testcontainers reads this; Docker Desktop 4.x
                  requires API >= 1.40
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>-Dnet.bytebuddy.experimental=true -Dapi.version=1.41</argLine>
                    <environmentVariables>
                        <DOCKER_HOST>unix://${user.home}/.docker/run/docker.sock</DOCKER_HOST>
                        <TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE>${user.home}/.docker/run/docker.sock</TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE>
                        <DOCKER_API_VERSION>1.41</DOCKER_API_VERSION>
                    </environmentVariables>
                    <includes>
                        <include>**/*Test.java</include>
                        <include>**/*Tests.java</include>
                        <include>**/*Int.java</include>
                        <include>**/*IT.java</include>
                    </includes>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
