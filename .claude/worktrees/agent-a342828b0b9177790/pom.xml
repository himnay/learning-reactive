<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Inherit Spring Boot's managed dependencies so every sub-module
         can omit <version> tags for well-known libraries. -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.4</version>
    </parent>

    <groupId>com.reactivespring</groupId>
    <artifactId>learning-reactive-parent</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>learning-reactive-parent</name>
    <description>Root POM — shared dependency management for all reactive service modules</description>

    <modules>
        <module>non-spring-reactive-reactor-core</module>
        <module>spring-reactive-service-info</module>
        <module>spring-reactive-service-review</module>
        <module>spring-reactive-service-movies</module>
        <module>spring-reactive-gateway</module>
        <module>spring-reactive-service-r2dbc</module>
    </modules>

    <properties>
        <java.version>25</java.version>
        <spring-cloud.version>2024.0.1</spring-cloud.version>
        <testcontainers.version>1.20.4</testcontainers.version>
        <jjwt.version>0.12.6</jjwt.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <!-- Spring Boot Testcontainers integration (@ServiceConnection) -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-testcontainers</artifactId>
                <version>3.4.4</version>
                <scope>test</scope>
            </dependency>
            <!-- spring-security-webflux is managed by Spring Boot BOM; declared here
                 so child modules can depend on it without specifying a version. -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-starter-security</artifactId>
            </dependency>
            <!-- JWT: jjwt-api is the compile-time API; impl and jackson are runtime-only. -->
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-api</artifactId>
                <version>${jjwt.version}</version>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-impl</artifactId>
                <version>${jjwt.version}</version>
                <scope>runtime</scope>
            </dependency>
            <dependency>
                <groupId>io.jsonwebtoken</groupId>
                <artifactId>jjwt-jackson</artifactId>
                <version>${jjwt.version}</version>
                <scope>runtime</scope>
            </dependency>
            <!-- postgresql Testcontainers module is already in testcontainers-bom -->
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>postgresql</artifactId>
                <scope>test</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                </plugin>
                <plugin>
                    <groupId>org.codehaus.mojo</groupId>
                    <artifactId>build-helper-maven-plugin</artifactId>
                    <version>3.6.0</version>
                </plugin>
            </plugins>
        </pluginManagement>

        <!-- Surefire declared in <plugins> (not just pluginManagement) so environment variables
             are inherited by all child modules automatically -->
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- net.bytebuddy.experimental: Mockito needs this to support Java 25 class version 69.
                         api.version: docker-java shaded inside Testcontainers reads this as a system property;
                         Docker Desktop 4.x dropped support for API < 1.40 so we pin to 1.41. -->
                    <argLine>-Dnet.bytebuddy.experimental=true -Dapi.version=1.41</argLine>
                    <environmentVariables>
                        <!-- Docker Desktop on Mac uses a non-standard socket path; Testcontainers needs this.
                             DOCKER_API_VERSION overrides docker-java's default (1.24) which Docker Desktop 4.x rejects. -->
                        <DOCKER_HOST>unix://${user.home}/.docker/run/docker.sock</DOCKER_HOST>
                        <TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE>${user.home}/.docker/run/docker.sock</TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE>
                        <DOCKER_API_VERSION>1.41</DOCKER_API_VERSION>
                        <REDIS_HOST>localhost</REDIS_HOST>
                        <POSTGRES_HOST>localhost</POSTGRES_HOST>
                    </environmentVariables>
                    <includes>
                        <include>**/*Test.java</include>
                        <include>**/*Tests.java</include>
                        <include>**/*Int.java</include>
                        <include>**/*IT.java</include>
                    </includes>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
